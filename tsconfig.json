{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2017"],
    "jsx": "react-native",
    "strict": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src", "examples"],
  "exclude": ["node_modules", "dist"]
}
